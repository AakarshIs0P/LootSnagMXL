# ─────────────────────────────────────────────────────────────────────────────
# LootSnag — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# DISCORD
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_test_guild_id_here

OWNER_ID=your_discord_user_id_here

# LOG CHANNEL
# Channel ID where bot sends internal logs (errors, cron info, API failures)
LOG_CHANNEL_ID=your_log_channel_id_here

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=


# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL API
# ─────────────────────────────────────────────────────────────────────────────

# RAWG 
# Sign up at: https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_key_here


# ─────────────────────────────────────────────────────────────────────────────
# BOT SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# Minimum deal discount % to alert (default 80)
DEFAULT_DEAL_THRESHOLD=80

# Default currency: INR or USD
DEFAULT_CURRENCY=INR

# Node environment
NODE_ENV=production
